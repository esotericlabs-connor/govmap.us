NEXT_PUBLIC_API_URL=http://localhost:8000

# Cross-zone links -- govmap.us (marketing) and app.govmap.us (platform) are
# one Next.js deployment split by middleware.ts, but since they're different
# hosts in production, links between them need to be absolute. Locally,
# *.localhost always resolves to loopback with zero config, so the defaults
# below work with no setup: http://localhost:3000 for marketing,
# http://app.localhost:3000 for the platform.
NEXT_PUBLIC_APP_URL=http://app.localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
