# Postgres connection string (async driver — asyncpg)
DATABASE_URL=postgresql+asyncpg://govmap:govmap@localhost:5432/govmap

# Comma-separated list of origins the API will accept browser requests from
CORS_ORIGINS=http://localhost:3000,https://govmap.us

# Credentials for the /internal/* ops endpoints (pipeline status dashboard).
# Leave both empty to keep those endpoints locked (recommended unless you need
# them). Set to access /internal/pipeline-status with HTTP Basic Auth.
INTERNAL_USER=
INTERNAL_PASSWORD=
