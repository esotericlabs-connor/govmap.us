# GovMap production environment — docker-compose reads this file for ${VAR}
# interpolation. Copy to `.env` on the server and fill in. NEVER commit the
# real .env (it's gitignored). Back up your filled-in .env somewhere safe (a
# password manager) — restoring it is what makes a box rebuild instant.
#
# Nothing here is irreplaceable: on a fresh box deploy.sh generates a new
# POSTGRES_PASSWORD (the DB re-loads from the pipeline), and the tunnel token
# can be re-fetched from the Cloudflare dashboard. A backup just saves the trip.

# Postgres password for the stack. deploy.sh generates one automatically if
# .env is absent; set it explicitly if you want a known/restored value.
POSTGRES_PASSWORD=

# Cloudflare Tunnel token for the dashboard-managed "govmap" tunnel — the ONLY
# per-box state needed to reconnect to the same tunnel and its routes.
# Get it from: Cloudflare dashboard -> the govmap tunnel -> connector install
# command (the eyJ... string after --token), or the tunnel's "Rotate token".
# Without it, the stack runs but the public site (govmap.us) stays down.
CLOUDFLARE_TUNNEL_TOKEN=

# Optional — unlock the /internal/* ops endpoints (locked when unset).
INTERNAL_USER=
INTERNAL_PASSWORD=

# Congress.gov API key — required for the bills (and later votes) pipeline.
# Free + instant from https://api.congress.gov/sign-up/. Without it the bills
# refresh records an error (the rest of the stack runs fine).
CONGRESS_GOV_API_KEY=

# Optional overrides (sensible production defaults live in docker-compose.yml):
# CORS_ORIGINS=https://govmap.us,https://app.govmap.us
# NEXT_PUBLIC_API_URL=https://api.govmap.us
# CONGRESS_NUMBER=119            # bump to 120 in Jan 2027
# CONGRESS_GOV_BILL_LIMIT=250    # raise to widen bill coverage per refresh
